# ── HUD evaluation ────────────────────────────────────────────────────────────
# Get from https://hud.ai → Settings → API keys
HUD_API_KEY=sk-hud-...

# ── Fireworks RL Training ─────────────────────────────────────────────────────
# Get from https://fireworks.ai → Account → API keys
FIREWORKS_API_KEY=fw_...

# Required for managed sampler + full GRPO training (Training API preview).
# Find in Fireworks dashboard → Account → Account ID
FIREWORKS_ACCOUNT_ID=

# Optional: override the Fireworks base URL (default: https://api.fireworks.ai)
# FIREWORKS_BASE_URL=https://api.fireworks.ai

# ── LLM providers (used by hud eval for the agent under test) ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
